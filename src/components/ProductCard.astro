---
import type { CollectionEntry } from 'astro:content';

interface Props {
	product: CollectionEntry<'products'>;
}

const { product } = Astro.props;
const accent = product.data.featured ? 'from-brand-green/20 via-white to-brand-yellow/20' : 'from-brand-blue/15 via-white to-brand-red/10';
---

<article class="section-card group relative overflow-hidden rounded-[2rem] p-6 sm:p-7">
	<div class:list={['absolute inset-0 -z-10 bg-linear-to-br', accent]}></div>
	<div class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
		<div class="space-y-4">
			<div class="flex flex-wrap items-center gap-3">
				<span class="rounded-full bg-brand-brown px-3 py-1 text-xs font-bold uppercase tracking-[0.22em] text-white">
					{product.data.badge}
				</span>
				<span class="text-sm font-semibold text-brand-brown/70">{product.data.category}</span>
			</div>
			<h3 class="font-display text-3xl text-brand-brown sm:text-4xl">{product.data.name}</h3>
			<p class="text-base leading-7 text-brand-brown/88">{product.data.summary}</p>
			<div class="inline-flex items-center gap-2 rounded-full border border-brand-brown/10 bg-white/80 px-4 py-2 text-sm font-semibold text-brand-brown/80">
				<span class="size-2 rounded-full bg-brand-green"></span>
				{product.data.origin}
			</div>
		</div>

		<div class="relative isolate">
			<div class="absolute inset-6 -z-10 rounded-[1.75rem] bg-brand-brown/10 blur-2xl"></div>
			<div class="overflow-hidden rounded-[2rem] border border-white/70 bg-white/80 p-4 shadow-[0_22px_55px_-28px_rgba(47,23,9,0.5)]">
				<img src={product.data.image} alt={product.data.name} class="aspect-[4/3] w-full object-cover transition duration-500 group-hover:scale-[1.03]" />
			</div>
		</div>
	</div>
</article>
