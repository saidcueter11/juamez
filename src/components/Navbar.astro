---
import BrandMark from './BrandMark.astro';
import Icon from './Icon.astro';
import { alternateLang, localizePath, sectionPath, useTranslations, type Lang } from '../i18n/utils';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const nextLang = alternateLang(lang);
const homePath = localizePath(lang, '/');
const switchPath = localizePath(nextLang, '/');
const links = [
	{ label: t.nav.company, href: sectionPath(lang, 'about') },
	{ label: t.nav.products, href: sectionPath(lang, 'products') },
	{ label: t.nav.process, href: sectionPath(lang, 'process') },
	{ label: t.nav.contact, href: sectionPath(lang, 'contact') },
];
---

<nav class="container-shell relative z-50 pt-5 sm:pt-6">
	<div class="section-card rounded-4xl px-5 py-4 sm:px-6">
		<div class="flex items-center justify-between">
			<a href={homePath} class="flex shrink-0 items-center gap-3">
				<BrandMark compact />
			</a>

			<!-- Desktop nav -->
			<div class="hidden items-center gap-5 text-sm font-semibold text-brand-brown/80 lg:flex">
				{links.map((link) => <a href={link.href} class="transition hover:text-brand-brown">{link.label}</a>)}
			</div>

			<div class="hidden items-center gap-3 lg:flex">
				<a
					href={sectionPath(lang, 'contact')}
					class="inline-flex items-center gap-2 rounded-full bg-brand-brown px-4 py-2 text-sm font-bold text-white transition hover:bg-brand-brown-soft"
				>
					<Icon name="message-circle" size={15} />
					{t.nav.contact}
				</a>
				<a
					href={switchPath}
					hreflang={nextLang}
					class="inline-flex items-center gap-2 rounded-full border border-brand-brown/12 bg-white/70 px-4 py-2 text-sm font-bold text-brand-brown transition hover:border-brand-brown/30 hover:bg-white"
				>
					<Icon name="languages" size={15} />
					{t.nav.language}
				</a>
			</div>

			<!-- Mobile hamburger -->
			<button
				type="button"
				id="menu-toggle"
				class="flex size-10 items-center justify-center rounded-xl border border-brand-brown/10 bg-white/60 text-brand-brown transition hover:bg-white lg:hidden"
				aria-label="Toggle menu"
				aria-expanded="false"
				aria-controls="mobile-menu"
			>
				<svg id="icon-open" class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
				</svg>
				<svg id="icon-close" class="hidden size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
				</svg>
			</button>
		</div>

		<!-- Mobile menu -->
		<div
			id="mobile-menu"
			class="mt-0 grid grid-rows-[0fr] overflow-hidden opacity-0 transition-all duration-300 ease-out lg:hidden"
			aria-hidden="true"
		>
			<div class="min-h-0">
				<div class="mt-4 border-t border-brand-brown/8 pt-4 translate-y-[-0.35rem] transition-transform duration-300 ease-out" id="mobile-menu-inner">
			<div class="flex flex-col gap-1">
				{links.map((link) => (
					<a href={link.href} class="block rounded-xl px-4 py-3 text-sm font-semibold text-brand-brown/85 transition hover:bg-brand-brown/5 hover:text-brand-brown">{link.label}</a>
				))}
			</div>
			<div class="mt-4 flex items-center gap-3">
				<a
					href={sectionPath(lang, 'contact')}
					class="flex-1 rounded-full bg-brand-brown px-4 py-2.5 text-center text-sm font-bold text-white transition hover:bg-brand-brown-soft"
				>
					{t.nav.contact}
				</a>
				<a
					href={switchPath}
					hreflang={nextLang}
					class="rounded-full border border-brand-brown/12 bg-white/70 px-4 py-2.5 text-sm font-bold text-brand-brown transition hover:border-brand-brown/30 hover:bg-white"
				>
					{t.nav.language}
				</a>
			</div>
				</div>
			</div>
		</div>
	</div>
</nav>

<script>
	const toggle = document.getElementById('menu-toggle');
	const menu = document.getElementById('mobile-menu');
	const menuInner = document.getElementById('mobile-menu-inner');
	const iconOpen = document.getElementById('icon-open');
	const iconClose = document.getElementById('icon-close');

	const setMenuState = (isOpen: boolean) => {
		menu?.classList.toggle('grid-rows-[1fr]', isOpen);
		menu?.classList.toggle('grid-rows-[0fr]', !isOpen);
		menu?.classList.toggle('opacity-100', isOpen);
		menu?.classList.toggle('opacity-0', !isOpen);
		menuInner?.classList.toggle('translate-y-0', isOpen);
		menuInner?.classList.toggle('translate-y-[-0.35rem]', !isOpen);
		menu?.setAttribute('aria-hidden', String(!isOpen));
		iconOpen?.classList.toggle('hidden', isOpen);
		iconClose?.classList.toggle('hidden', !isOpen);
		toggle?.setAttribute('aria-expanded', String(isOpen));
	};

	toggle?.addEventListener('click', () => {
		const isOpen = toggle.getAttribute('aria-expanded') !== 'true';
		setMenuState(isOpen);
	});

	menu?.querySelectorAll('a').forEach((link) => {
		link.addEventListener('click', () => {
			setMenuState(false);
		});
	});

	window.addEventListener('resize', () => {
		if (window.innerWidth >= 1024) {
			setMenuState(false);
		}
	});

	// Back to top button
	const topBtn = document.getElementById('back-to-top');
	const topThreshold = 400;

	const updateTopBtn = () => {
		const show = window.scrollY > topThreshold;
		topBtn?.classList.toggle('opacity-0', !show);
		topBtn?.classList.toggle('pointer-events-none', !show);
		topBtn?.classList.toggle('translate-y-3', !show);
		topBtn?.classList.toggle('opacity-100', show);
		topBtn?.classList.toggle('pointer-events-auto', show);
		topBtn?.classList.toggle('translate-y-0', show);
	};

	window.addEventListener('scroll', updateTopBtn, { passive: true });
	updateTopBtn();

	topBtn?.addEventListener('click', () => {
		window.scrollTo({ top: 0, behavior: 'smooth' });
	});
</script>
