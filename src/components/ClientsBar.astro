---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="container-shell mt-16 sm:mt-20">
	<div class="text-center">
		<p class="eyebrow mx-auto bg-brand-green/12 text-brand-brown ring-1 ring-brand-brown/8">{t.clients.eyebrow}</p>
		<h2 class="mt-4 font-display text-2xl text-brand-brown sm:text-3xl">{t.clients.title}</h2>
	</div>

	<div class="mt-8 flex flex-wrap items-center justify-center gap-8 sm:gap-12 lg:gap-16">
		{t.clients.items.map((client) => (
			<div class="flex flex-col items-center gap-2 opacity-70 grayscale transition hover:opacity-100 hover:grayscale-0">
				<!-- Placeholder: replace with actual client logo -->
				<div class="flex h-12 w-28 items-center justify-center rounded-lg border border-brand-brown/8 bg-white/80 px-4 py-2 text-center sm:h-14 sm:w-32">
					<span class="text-xs font-bold uppercase tracking-wider text-brand-brown/60">{client.name}</span>
				</div>
			</div>
		))}
	</div>
</section>
