---
import type { CollectionEntry } from 'astro:content';
import ContactForm from './ContactForm.astro';
import ClientsBar from './ClientsBar.astro';
import Footer from './Footer.astro';
import Navbar from './Navbar.astro';
import ProductCard from './ProductCard.astro';
import BrandMark from './BrandMark.astro';
import Icon from './Icon.astro';
import { useTranslations, type Lang } from '../i18n/utils';

const statIcons = ['clock', 'users', 'package'] as const;
const highlightIcons = ['leaf', 'ship', 'handshake'] as const;
const processIcons = ['search', 'shield-check', 'box', 'truck'] as const;

interface Props {
	lang: Lang;
	products: CollectionEntry<'products'>[];
}

const { lang, products } = Astro.props;
const t = useTranslations(lang);
const heroProducts = products.slice(0, 3);
---

<div class="relative isolate overflow-hidden">
	<Navbar lang={lang} />

	<main class="pb-10 pt-6 sm:pt-8">
		<!-- ═══ HERO ═══ -->
		<section class="container-shell relative grid gap-8 pb-14 text-white sm:pb-18 lg:grid-cols-[1.02fr_0.98fr] lg:items-center lg:gap-12 lg:pb-10">
			<div class="absolute inset-y-0 left-1/2 -z-10 w-screen -translate-x-1/2 bg-[linear-gradient(135deg,#2f1709_0%,#59331d_55%,#2f1709_100%)]"></div>
			<div class="absolute inset-y-0 left-1/2 -z-10 w-screen -translate-x-1/2 bg-[radial-gradient(circle_at_top_left,rgba(224,194,59,0.34),transparent_32%),radial-gradient(circle_at_80%_20%,rgba(47,136,211,0.2),transparent_30%)]"></div>
			<div class="absolute -left-[20vw] top-32 -z-10 h-72 w-72 rounded-full bg-brand-green/20 blur-3xl animate-float"></div>
			<div class="absolute -right-[12vw] top-20 -z-10 h-64 w-64 rounded-full bg-brand-yellow/20 blur-3xl animate-float-slow"></div>

			<div class="relative z-10 max-w-2xl py-4 sm:py-8 animate-fade-in-up">
				<p class="eyebrow bg-white/12 text-white ring-1 ring-white/12">{t.hero.eyebrow}</p>
				<h1 class="mt-6 max-w-xl font-display text-4xl leading-[0.95] sm:text-5xl md:text-6xl lg:text-7xl">{t.hero.title}</h1>
				<p class="mt-6 max-w-lg text-base leading-8 text-white/90 sm:text-lg lg:max-w-xl">{t.hero.description}</p>

				<div class="mt-8 flex flex-wrap gap-3">
					<a href="#contact" class="inline-flex items-center gap-2 rounded-full bg-brand-yellow px-6 py-3 text-sm font-bold text-brand-brown transition hover:bg-white">
						<Icon name="send" size={16} />
						{t.hero.primaryCta}
					</a>
					<a href="#products" class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/8 px-6 py-3 text-sm font-bold text-white transition hover:bg-white/16">
						<Icon name="package" size={16} />
						{t.hero.secondaryCta}
					</a>
				</div>

				<div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-3 stagger-children" data-reveal>
					{t.hero.stats.map((stat, i) => (
						<div class="glass-panel rounded-3xl px-4 py-4 hover-lift">
							<Icon name={statIcons[i]} size={20} class="mb-2 text-brand-yellow" />
							<p class="text-2xl font-black uppercase tracking-[0.12em] text-white">{stat.value}</p>
							<p class="mt-2 text-sm leading-6 text-white/88">{stat.label}</p>
						</div>
					))}
				</div>
			</div>

			<div class="animate-fade-in-up delay-2 lg:pl-6">
				<div class="rounded-[2.25rem] border border-white/12 bg-brand-brown/70 p-5 shadow-[0_36px_90px_-42px_rgba(0,0,0,0.8)] backdrop-blur-md lg:mx-auto lg:max-w-100 lg:bg-white/10">
					<div class="flex items-center justify-between text-white">
						<p class="text-xs font-bold uppercase tracking-[0.26em] text-white/78">{t.hero.showcaseTitle}</p>
						<BrandMark light compact />
					</div>
					<p class="mt-4 max-w-xs text-sm leading-6 text-white/88">{t.hero.showcaseCopy}</p>
					<div class="mt-5 grid gap-4">
						{heroProducts.map((product) => (
							<div class="rounded-3xl border border-white/12 bg-brand-brown/90 p-3 lg:bg-brand-brown/60">
								<div class="grid grid-cols-[4.5rem_1fr] items-center gap-4">
									<div class="rounded-[1.15rem] bg-white/10 p-1.5 ring-1 ring-white/12">
										<!-- Placeholder: replace with product photo -->
										<div class="overflow-hidden rounded-[0.9rem] bg-white/85 shadow-sm">
											<img src={product.data.image} alt={product.data.name} class="block aspect-square w-full object-cover" />
										</div>
									</div>
									<div>
										<p class="text-xs font-bold uppercase tracking-[0.22em] text-brand-yellow">{product.data.category}</p>
										<p class="mt-1 font-display text-2xl text-white">{product.data.name}</p>
										<p class="mt-1 text-sm text-white/82">{product.data.badge}</p>
									</div>
								</div>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- ═══ ABOUT ═══ -->
		<section id="about" class="container-shell mt-16 sm:mt-20">
			<div class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr] lg:items-start">
				<div class="reveal-left rounded-[2.25rem] border border-brand-brown/12 bg-[linear-gradient(160deg,#2f1709_0%,#59331d_100%)] px-6 py-8 text-white shadow-[0_28px_90px_-40px_rgba(47,23,9,0.55)] sm:px-8">
					<p class="eyebrow bg-white/10 text-white ring-1 ring-white/12">{t.about.eyebrow}</p>
					<h2 class="mt-5 max-w-lg font-display text-4xl leading-tight sm:text-5xl">{t.about.title}</h2>
					<p class="mt-5 max-w-xl text-base leading-8 text-white/92">{t.about.description}</p>

					<!-- Mission, Vision, Values -->
					<div class="mt-8 space-y-6 border-t border-white/12 pt-6">
						<div>
							<h3 class="flex items-center gap-2 text-sm font-black uppercase tracking-[0.22em] text-brand-yellow"><Icon name="target" size={16} />{t.about.mission.title}</h3>
							<p class="mt-2 text-sm leading-7 text-white/88">{t.about.mission.copy}</p>
						</div>
						<div>
							<h3 class="flex items-center gap-2 text-sm font-black uppercase tracking-[0.22em] text-brand-yellow"><Icon name="eye" size={16} />{t.about.vision.title}</h3>
							<p class="mt-2 text-sm leading-7 text-white/88">{t.about.vision.copy}</p>
						</div>
						<div>
							<h3 class="flex items-center gap-2 text-sm font-black uppercase tracking-[0.22em] text-brand-yellow"><Icon name="heart" size={16} />{t.about.values.title}</h3>
							<div class="mt-3 flex flex-wrap gap-2">
								{t.about.values.items.map((value) => (
									<span class="inline-flex items-center gap-1.5 rounded-full border border-white/15 bg-white/8 px-3 py-1 text-xs font-semibold text-white/90"><Icon name="check-circle" size={12} />{value}</span>
								))}
							</div>
						</div>
					</div>
				</div>

				<div class="reveal-right grid content-start gap-4 sm:grid-cols-2 xl:grid-cols-3 stagger-children">
					{t.about.highlights.map((highlight, i) => (
						<article class="rounded-4xl border border-brand-brown/8 bg-white/98 p-6 shadow-[0_24px_80px_-36px_rgb(47_23_9/0.22)] hover-lift">
							<span class="mb-3 inline-flex size-10 items-center justify-center rounded-2xl bg-brand-green/10 text-brand-green"><Icon name={highlightIcons[i]} size={20} /></span>
							<p class="text-sm font-black uppercase tracking-[0.22em] text-brand-green">{highlight.title}</p>
							<p class="mt-4 text-sm leading-7 text-brand-brown/90">{highlight.copy}</p>
						</article>
					))}

					<!-- Export packaging photo -->
					<div class="col-span-full mt-2 overflow-hidden rounded-4xl border border-brand-brown/8 bg-brand-brown/5 shadow-[0_24px_80px_-36px_rgb(47_23_9/0.22)]">
						<img src="/images/campo-agricultor.jpg" alt="Agricultor en campo colombiano" class="block aspect-21/9 w-full object-cover" loading="lazy" />
					</div>
				</div>
			</div>
		</section>

		<!-- ═══ PRODUCTS ═══ -->
		<section id="products" class="container-shell mt-16 sm:mt-20">
			<div class="reveal max-w-3xl">
				<p class="eyebrow bg-brand-yellow/18 text-brand-brown ring-1 ring-brand-brown/8">{t.products.eyebrow}</p>
				<h2 class="mt-5 max-w-3xl font-display text-4xl text-brand-brown sm:text-5xl">{t.products.title}</h2>
				<p class="mt-4 max-w-3xl text-base leading-8 text-brand-brown/85">{t.products.description}</p>
			</div>

			<div class="mt-8 grid gap-6 stagger-children" data-reveal>
				{products.map((product) => <ProductCard product={product} />)}
			</div>

			<div class="reveal mt-8 text-center">
				<a href="#contact" class="inline-flex items-center gap-2 rounded-full bg-brand-green px-7 py-3 text-sm font-bold text-white transition hover:bg-brand-brown">
					<Icon name="send" size={16} />
					{t.products.cta}
				</a>
			</div>
		</section>

		<!-- ═══ PROCESS ═══ -->
		<section id="process" class="container-shell mt-16 sm:mt-20">
			<div class="reveal-scale section-card rounded-[2.5rem] p-6 sm:p-8 lg:p-10">
				<div class="grid gap-8 lg:grid-cols-[0.88fr_1.12fr]">
					<div>
						<p class="eyebrow bg-brand-red/12 text-brand-brown ring-1 ring-brand-brown/8">{t.process.eyebrow}</p>
						<h2 class="mt-5 max-w-xl font-display text-4xl text-brand-brown sm:text-5xl">{t.process.title}</h2>
						<p class="mt-4 max-w-lg text-base leading-8 text-brand-brown/85">{t.process.description}</p>

						<!-- Process/field image -->
						<div class="mt-6 overflow-hidden rounded-3xl border border-brand-brown/8">
							<img src="/images/campo-name.jpg" alt="Plantación de ñame en el campo colombiano" class="block aspect-video w-full object-cover" loading="lazy" />
						</div>
					</div>
					<div class="grid gap-4 sm:grid-cols-2 stagger-children" data-reveal>
						{t.process.items.map((item, i) => (
							<article class="rounded-[1.8rem] border border-brand-brown/8 bg-white/95 p-5 shadow-[0_18px_45px_-32px_rgba(47,23,9,0.45)] hover-lift">
								<span class="mb-2 inline-flex size-10 items-center justify-center rounded-2xl bg-brand-red/8 text-brand-red"><Icon name={processIcons[i]} size={20} /></span>
								<h3 class="font-display text-2xl text-brand-brown">{item.title}</h3>
								<p class="mt-3 text-sm leading-7 text-brand-brown/85">{item.copy}</p>
							</article>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- ═══ CONTACT ═══ -->
		<section id="contact" class="container-shell mt-16 sm:mt-20">
			<div class="grid gap-6 lg:grid-cols-[0.92fr_1.08fr] lg:items-start">
				<div class="reveal-left rounded-[2.25rem] border border-brand-brown/12 bg-[linear-gradient(160deg,#2f1709_0%,#59331d_100%)] px-6 py-8 text-white shadow-[0_28px_90px_-40px_rgba(47,23,9,0.55)] sm:px-8">
					<p class="eyebrow bg-white/10 text-white ring-1 ring-white/12">{t.contact.eyebrow}</p>
					<h2 class="mt-5 max-w-lg font-display text-4xl leading-tight sm:text-5xl">{t.contact.title}</h2>
					<p class="mt-4 max-w-xl text-base leading-8 text-white/92">{t.contact.description}</p>
					<ul class="mt-8 space-y-4">
						{t.contact.expectations.map((item) => (
							<li class="flex items-start gap-3 text-sm leading-7 text-white/95">
								<Icon name="check-circle" size={18} class="mt-1 shrink-0 text-brand-yellow" />
								<span>{item}</span>
							</li>
						))}
					</ul>

					<!-- Contact details -->
					<div class="mt-8 space-y-4 border-t border-white/12 pt-6">
						<h3 class="text-sm font-black uppercase tracking-[0.22em] text-brand-yellow">{t.contact.details.title}</h3>
						<div class="space-y-3 text-sm text-white/90">
							<p>
								<span class="block text-xs font-bold uppercase tracking-wider text-white/60">{t.contact.details.manager.label}</span>
								<a href={`mailto:${t.contact.details.manager.email}`} class="inline-flex items-center gap-1.5 underline underline-offset-2 hover:text-brand-yellow"><Icon name="mail" size={14} />{t.contact.details.manager.email}</a>
							</p>
							<p>
								<span class="block text-xs font-bold uppercase tracking-wider text-white/60">{t.contact.details.usRep.label}</span>
								<a href={`mailto:${t.contact.details.usRep.email}`} class="inline-flex items-center gap-1.5 underline underline-offset-2 hover:text-brand-yellow"><Icon name="mail" size={14} />{t.contact.details.usRep.email}</a>
							</p>
							<div class="flex flex-wrap gap-3 pt-1">
								{t.contact.details.phones.map((phone) => (
									<a href={`tel:${phone.replace(/\s/g, '')}`} class="inline-flex items-center gap-1.5 rounded-full border border-white/15 bg-white/8 px-3 py-1 text-xs font-semibold hover:bg-white/16"><Icon name="phone" size={12} />{phone}</a>
								))}
							</div>
							<p class="flex items-center gap-1.5 text-white/70"><Icon name="map-pin" size={14} /> {t.contact.details.location}</p>
						</div>
					</div>
				</div>

				<ContactForm lang={lang} />
			</div>
		</section>
	</main>

	<Footer lang={lang} />

	<!-- Back to top -->
	<button
		id="back-to-top"
		aria-label="Back to top"
		class="fixed bottom-6 right-6 z-50 flex size-12 items-center justify-center rounded-full bg-brand-brown text-white shadow-lg opacity-0 pointer-events-none translate-y-3 transition-all duration-300 hover:bg-brand-brown-soft hover:shadow-xl sm:bottom-8 sm:right-8"
	>
		<svg class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
			<path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
		</svg>
	</button>
</div>

<script>
	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add('is-visible');
					observer.unobserve(entry.target);
				}
			});
		},
		{ threshold: 0.08, rootMargin: '0px 0px -60px 0px' }
	);

	// Observe all reveal variants + stagger parents
	document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale, .stagger-children, [data-reveal]').forEach((el) => observer.observe(el));
</script>
